# Build artifacts
/target
**/target

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Rust
**/*.rs.bk
# NOTE: Cargo.lock IS committed for this binary project.
# This ensures reproducible builds for end users.

# PlexusDB runtime data — never commit live data or certificates
plexus-data/
plexus-certs/
plexus-bench/
*.db
*.db-shm
*.db-wal

# Generated protobuf code (pre-generated stubs are committed instead)
# Uncomment the line below only if you have protoc installed and want to regenerate:
# crates/plexus-api/src/generated/*.rs
# !crates/plexus-api/src/generated/.gitkeep

# Temp / probe files
*.tmp
*.bak
.plexus_probe_tmp

# Environment secrets — never commit these
.env
.env.local
